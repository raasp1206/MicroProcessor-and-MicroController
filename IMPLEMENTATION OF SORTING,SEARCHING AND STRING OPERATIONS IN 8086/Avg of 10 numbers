
                OUTPUT 2500AD
.ORG 2000H
DATA SEGMENT
ARRAY DB 01H,02H,03H,04H,05H,06H,07H,08H,09H,0AH
SUM DW 0000H
AVG DB 00H
DATA ENDS
CODE SEGMENT
        ASSUME CS:CODE,DS:DATA
        MOV AX,DATA
        MOV DS,AX
        MOV SI,OFFSET ARRAY
        MOV CX,0AH
        MOV AX,0000H
L1:     MOV BL,[SI]
        ADD AL,BL
        ADC AH,00H
        INC SI
        LOOP L1

        MOV SUM,AX
        MOV BL,0AH
        DIV BL
        MOV AVG,AL
        HLT
CODE ENDS
END
